<Window x:Class="RevitDevelop.Tools.Schedules.view.ScheduleSettingModelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:RevitDevelop.Tools.Schedules.view"
    mc:Ignorable="d"
    mc:Ignorable="d"
    Title="ScheduleView" 
    WindowStartupLocation="CenterScreen"
    MinHeight="400"
    Height="400" 
    Width="500">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="25"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="25"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <ListView 
            x:Name="dataModelProjects"
            Grid.Column="1"
            SelectionMode="Single"
            ItemsSource="{Binding ModelProjects, UpdateSourceTrigger=PropertyChanged}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid IsEnabled="{Binding CanDelete}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock 
                            Margin="0,0,10,0"
                            Grid.Column="0"
                            VerticalAlignment="Center" 
                            Text="{Binding Name}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <StackPanel
            VerticalAlignment="Bottom"
            HorizontalAlignment="Right"
            Grid.Row="1">
            <StackPanel 
            Orientation="Horizontal">
                <Button
                    Command="{Binding OnLoadModelsCmd}"
                    Content="Select"
                    Width="70"/>
                <Button
                    Command="{Binding OnOkCmd}"
                    Margin="10,0,0,0"
                    Content="OK"
                    Width="70"/>
                <Button
                    Command="{Binding OnCancelCmd}"
                    Margin="10,0,0,0"
                    Content="Cancel"
                    Width="70"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
