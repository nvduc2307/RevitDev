<Window x:Class="RevitDevelop.Tools.Schedules.view.ScheduleMappingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="RevitDevelop.Tools.Schedules.view"
        mc:Ignorable="d"
        Title="Setting Mapping" 
        WindowStartupLocation="CenterScreen"
        Height="300" 
        Width="600">
    <Window.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <DataGrid
            ItemsSource="{Binding MappingRecordSettings}"
            SelectionMode="Single"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            EnableColumnVirtualization="True"
            SelectionUnit="FullRow"
            HorizontalGridLinesBrush="LightGray" 
            VerticalGridLinesBrush="LightGray"
            ColumnWidth="*">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="ファミリ名">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox 
                                IsReadOnly="True"
                                Height="25"
                                Text="{Binding FamilyName}"
                                VerticalContentAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="タイプ名">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox 
                                IsReadOnly="True"
                                Height="25"
                                Text="{Binding TypeName}"
                                VerticalContentAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="工事項目">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox 
                                IsReadOnly="True"
                                Height="25"
                                Text="{Binding WorkItem}"
                                VerticalContentAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Grid.Row="1">
            <StackPanel Orientation="Horizontal">
                <Button
                    Content="Import"
                    Command="{Binding ImportCommand}"
                    Margin="0,0,10,0"
                    Width="70"
                    Height="25"/>
                <Button
                    Content="Export"
                    Command="{Binding ExportCommand}"
                    Margin="0,0,10,0"
                    Width="70"
                    Height="25"/>
                <Button
                    Content="Ok"
                    Command="{Binding OkCommand}"
                    Margin="0,0,10,0"
                    Width="70"
                    Height="25"/>
                <Button
                    Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Width="70"
                    Height="25"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
