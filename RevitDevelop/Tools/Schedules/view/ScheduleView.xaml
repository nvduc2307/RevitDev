<Window x:Class="RevitDevelop.Tools.Schedules.view.ScheduleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RevitDevelop.Tools.Schedules.view"
        mc:Ignorable="d"
        Title="ScheduleView" 
        WindowStartupLocation="CenterScreen"
        MinHeight="500"
        Height="600" 
        Width="800">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="25"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="25"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="MinimalScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="3" Background="#95A5A6"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MinimalScrollBar" TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="6"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track Name="PART_Track" IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="False"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource MinimalScrollBarThumb}" />
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="False"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="6"/>
                    <Setter Property="Height" Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource MinimalScrollBarThumb}" />
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="MinimalScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Grid.IsSharedSizeScope="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Row="0" Grid.Column="0"/>
                            <ScrollBar Name="PART_HorizontalScrollBar" Orientation="Horizontal" Grid.Row="1" Grid.Column="0" Value="{TemplateBinding HorizontalOffset}" Maximum="{TemplateBinding ScrollableWidth}" ViewportSize="{TemplateBinding ViewportWidth}" Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" Style="{StaticResource MinimalScrollBar}"/>
                            <ScrollBar Name="PART_VerticalScrollBar" Orientation="Vertical" Grid.Row="0" Grid.Column="1" Value="{TemplateBinding VerticalOffset}" Maximum="{TemplateBinding ScrollableHeight}" ViewportSize="{TemplateBinding ViewportHeight}" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" Style="{StaticResource MinimalScrollBar}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="File Output"/>
                <TextBox Text="{Binding ScheduleSetting.PathOutput}" Grid.Column="1"/>
                <Button Command="{Binding OnChooseFileOutputCmd}" Margin="5,0,0,0" Content="..." Grid.Column="2"/>
            </Grid>
        </StackPanel>

        <StackPanel Margin="0,10,0,0" Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="File Models"/>
                <TextBox Text="{Binding ScheduleSetting.PathModels}" Grid.Column="1"/>
                <Button Command="{Binding OnChooseFileModelCmd}" Margin="5,0,0,0" Content="..." Grid.Column="2"/>
            </Grid>
        </StackPanel>

        <TabControl
            x:Name="TabScheduleSheets"
            ItemsSource="{Binding ScheduleSetting.ScheduleSheets}"
            Margin="0,10,0,0"
            Grid.Row="2">

            <TabControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </TabControl.ItemsPanel>

            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding SheetName}" VerticalAlignment="Center" Margin="5,2"/>

                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sheet Name"/>
                                <TextBox Text="{Binding SheetName, UpdateSourceTrigger=PropertyChanged, Delay=100}" Grid.Column="1"/>
                            </Grid>
                        </StackPanel>

                        <GroupBox Grid.Row="1" Margin="0,10,0,0" Padding="10" Header="Setting Models">
                            <Border BorderBrush="#ACACAC" BorderThickness="1,1,0,1">
                                <ScrollViewer Style="{StaticResource MinimalScrollViewer}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="0" Margin="0">
                                    <TabControl ItemsSource="{Binding ProjectInfomationModels}" Background="White" IsHitTestVisible="True" Focusable="True" Padding="0" Margin="0">
                                        <TabControl.ItemContainerStyle>
                                            <Style TargetType="TabItem">
                                                <Setter Property="MinWidth" Value="100"/>
                                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="VerticalAlignment" Value="Stretch"/>
                                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TabItem">
                                                            <Border Background="White" BorderBrush="#ACACAC" BorderThickness="0,0,1,0" MinWidth="{TemplateBinding MinWidth}">
                                                                <ContentPresenter ContentSource="Header" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TabControl.ItemContainerStyle>
                                        <TabControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1" IsItemsHost="True" Margin="0"/>
                                            </ItemsPanelTemplate>
                                        </TabControl.ItemsPanel>
                                        <TabControl.Template>
                                            <ControlTemplate TargetType="TabControl">
                                                <Grid Background="White">
                                                    <ItemsPresenter />
                                                </Grid>
                                            </ControlTemplate>
                                        </TabControl.Template>
                                        <TabControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Background="White">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="35"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <Border Background="#F0F4F8" BorderThickness="0,0,0,1" BorderBrush="#ACACAC">
                                                        <TextBlock Text="{Binding ProjectNameInExcel}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Grid Grid.Row="1">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="auto"/>
                                                            <RowDefinition/>
                                                        </Grid.RowDefinitions>
                                                        <TextBox 
                                                            Margin="5,5,5,0"
                                                            Padding="5,0,0,0"
                                                            VerticalAlignment="Top"
                                                            Text="{Binding SearchModelContain, UpdateSourceTrigger=PropertyChanged, Delay=100}"
                                                            Grid.Row="0" />
                                                        <ListView 
                                                            VerticalAlignment="Top"
                                                            Margin="0,10,0,0"
                                                            Grid.Row="1" 
                                                            ItemsSource="{Binding ProjectNameInRevitsTarget}" 
                                                            BorderThickness="0" 
                                                            Background="Transparent">
                                                            <ListView.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="5,2"/>
                                                                </DataTemplate>
                                                            </ListView.ItemTemplate>
                                                        </ListView>
                                                    </Grid>
                                                </Grid>
                                            </DataTemplate>
                                        </TabControl.ItemTemplate>
                                    </TabControl>
                                </ScrollViewer>
                            </Border>
                        </GroupBox>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Grid.Row="3">
            <Button Command="{Binding OnNewSheetCmd}" Content="+ New Sheet" Width="90" FontWeight="Bold"/>
        </StackPanel>

        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Grid.Row="3">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding OnSettingMappingCmd}" Margin="10,0,0,0" Content="Mapping" Width="70"/>
                <Button Command="{Binding OnOkCmd}" Margin="10,0,0,0" Content="OK" Width="70"/>
                <Button Command="{Binding OnCancelCmd}" Margin="10,0,0,0" Content="Cancel" Width="70"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>