<Window x:Class="RevitDevelop.Tools.Schedules.view.ScheduleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RevitDevelop.Tools.Schedules.view"
        mc:Ignorable="d"
        Title="ScheduleView" 
        WindowStartupLocation="CenterScreen"
        MinHeight="500"
        Height="500" 
        Width="600">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="25"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="25"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="File Output"/>
                <TextBox
                    Text="{Binding PathFileOutput}"
                    Grid.Column="1"/>
                <Button
                    Command="{Binding OnChooseFileOutputCmd}"
                    Margin="5,0,0,0"
                    Content="..."
                    Grid.Column="2"/>
            </Grid>
        </StackPanel>
        <StackPanel Grid.Row="1">
            <GroupBox 
                Margin="0,10,0,0"
                Header="models">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel HorizontalAlignment="Left">
                        <Button
                            Command="{Binding OnAddModelCmd}"
                            Content="+"
                            Height="40"
                            Width="40"/>
                        <Button
                            Command="{Binding OnRemoveModelCmd}"
                            Margin="0,10,0,0"
                            Content="-"
                            Height="40"
                            Width="40"/>
                    </StackPanel>
                    <ListView 
                        x:Name="dataModelProjects"
                        Grid.Column="1"
                        SelectionMode="Single"
                        ItemsSource="{Binding ModelProjects, UpdateSourceTrigger=PropertyChanged}"
                        MaxHeight="300"
                        MinHeight="100">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid IsEnabled="{Binding CanDelete}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock 
                                        Margin="0,0,10,0"
                                        Grid.Column="0"
                                        VerticalAlignment="Center" 
                                        Text="{Binding Name}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </GroupBox>
        </StackPanel>
        <TabControl 
            Margin="0,10,0,0"
            Grid.Row="2">
            <TabItem Header="給水・給湯">
                <StackPanel>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Sheet Name"/>
                        <TextBox
                            Text="{Binding SheetNameWaterAndHotWateSupply}"
                            HorizontalAlignment="Left"
                            Grid.Column="1"
                            Width="100"/>
                    </Grid>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Schedules Name"/>
                        <TextBox
                            Text="{Binding ScheduleNameWaterAndHotWateSupply}"
                            Grid.Column="1"
                            TextWrapping="Wrap"
                            Height="50"/>
                    </Grid>
                </StackPanel>
            </TabItem>
            <TabItem Header="排水">
            </TabItem>
            <TabItem Header="衛生">
            </TabItem>
            <TabItem Header="換気・LS">
            </TabItem>
            <TabItem Header="換気・LH">
            </TabItem>
        </TabControl>
        <StackPanel
            VerticalAlignment="Bottom"
            HorizontalAlignment="Right"
            Grid.Row="3">
            <StackPanel 
                Orientation="Horizontal">
                <Button
                    Command="{Binding OnSettingMappingCmd}"
                    Content="Mapping"
                    Width="70"/>
                <Button
                    Command="{Binding OnOkCmd}"
                    Margin="10,0,0,0"
                    Content="OK"
                    Width="70"/>
                <Button
                    Command="{Binding OnCancelCmd}"
                    Margin="10,0,0,0"
                    Content="Cancel"
                    Width="70"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
